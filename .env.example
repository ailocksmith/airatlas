# readsb/tar1090 aircraft feed. With host networking on the Pi, this usually
# points at the Ultrafeeder port published on the Pi itself.
AIRCRAFT_URL=http://localhost:8080/data/aircraft.json

# Required for Planespotters server-side API identification.
# Use an email address or contact URL that Planespotters can use to reach you.
PLANESPOTTERS_CONTACT=your-email@example.com

# FlightRadar24 REST API token. This is sent only by the backend.
FR24_API_TOKEN=your-fr24-api-token

# summary-first saves credits and falls back to Full when needed.
# Set full-only to restore the v3 lookup behavior.
FR24_ROUTE_MODE=summary-first
